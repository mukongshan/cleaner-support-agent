# 本地开发配置模板
# 使用方法：
# 1. 复制此文件并重命名为 application-local.yml
# 2. 填入实际的配置值
# 3. 在 application.yml 中添加 spring.profiles.include: local 或设置环境变量
#
# 注意：application-local.yml 已被 .gitignore 忽略，不会提交到版本控制

app:
  dify:
    # Dify API Key（从 Dify 平台获取）
    api-key: your-dify-api-key-here

  # 如需覆盖其他敏感配置，可在此添加
  # jwt:
  #   secret: your-production-jwt-secret

# 如需覆盖数据库配置
# spring:
#   datasource:
#     username: your-db-username
#     password: your-db-password
